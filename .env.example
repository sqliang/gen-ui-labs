# GenUI Labs · 环境变量模板
# 复制到 .env.local 并填 key（.env.local 已经被 .gitignore，不会入仓）

# === 必填：真实流式（已验证） ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# get key → https://platform.deepseek.com/api_keys
# 用途：Lab 1.1.1 Markdown 协议用真 SSE，ag-ui / a2ui 端到端测试

# === 可选：provider 矩阵 ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# get key → https://platform.openai.com/api-keys
# models: gpt-4o · gpt-4o-mini · gpt-4.1

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# get key → https://console.anthropic.com/settings/keys
# models: claude-sonnet-4-5 · claude-haiku-4-5

GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxx
# get key → https://aistudio.google.com/apikey
# models: gemini-2.5-pro · gemini-2.5-flash

QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# get key → https://dashscope.console.aliyun.com/apiKey
# models: qwen-max · qwen-plus
# 用 DashScope OpenAI 兼容端点：https://dashscope.aliyuncs.com/compatible-mode/v1

# === 本地 ===
# OLLAMA_HOST=http://localhost:11434
# Ollama 不需要 key，只配 host 即可

# === 调试 ===
# 强制 dark 模式覆盖（默认就 dark；这里为了文档完整性列出来）
# NEXT_PUBLIC_DEFAULT_THEME=dark
